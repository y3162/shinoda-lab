{
    "direction": "clean2noisy",
    "model": {
        "n_encoder_layers": 6,
        "n_decoder_layers": 6,
        "d_model": 32,
        "n_heads": 8,
        "context_length": 512
    },
    "train": {
        "train_subsets": ["train-clean-360"],
        "valid_subsets": ["dev-clean"],
        "tokenizer_path": "data/checkpoints/tokenizer/sp_bpe",
        "batch_size": 128,
        "num_workers": 4,
        "learning_rate": 0.0001,
        "epochs": 100,
        "seed": 42,
        "summary_interval": 100
    },
    "env": {
        "output_dir": "data/checkpoints/clean2noisy"
    }
}
